        - id: 79695df727454035917ee9e463815b4e
          blockGroup: 487ba3475a5f4d1c85b58fd351c60541
          sortingKey: "000003"
          contentHash: c11a7207
          type: code
          content: >-
            # Imports

            import numpy as np

            import pandas as pd

