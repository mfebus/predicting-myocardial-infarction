          contentHash: 31fd1f19
          type: code
          content: >-
            import pandas as pd

            import numpy as np

            import pickle

            import matplotlib.pyplot as plt

            import seaborn as sns


            from sklearn.preprocessing import StandardScaler

            from sklearn.cluster import KMeans

            from sklearn.metrics import silhouette_score, davies_bouldin_score, calinski_harabasz_score

            from sklearn.decomposition import PCA

            from sklearn.impute import SimpleImputer

            from scipy.cluster.hierarchy import linkage, dendrogram, fcluster
          metadata:
            execution_context_id: f96c8630-e291-475d-9374-ee9251eb52f6
        - id: 73cf110bce804d6a8b1fc55e4b1e16c1
          blockGroup: 3adca56250e34c7596baa629d9a9df99
          sortingKey: "000002"
          contentHash: 6f043345
          type: code
          content: >-
            # Load original dataset

            df = pd.read_csv('/work/model_myocardial_infarction/dataset/processed_data.csv')


            # Load selected features through EDA

            path = "/work/model_myocardial_infarction/dataset/selected_features.pkl"

            with open(path, "rb") as f:
                selected_features = pickle.load(f)

            print(len(selected_features))

            print(selected_features[:10])


            # Target

            TARGET = "_MICHD" # 1 = Report having MI or CHD, 2 = Did not report having MI or CHD, BLANK = Not
            asked/Missing


            # Cluster dataset

            cluster_df = df[selected_features].copy()
          metadata:
            execution_context_id: f96c8630-e291-475d-9374-ee9251eb52f6
        - id: 0ec8e1ff54e0475792d4e016b5645213
          blockGroup: 317e024f150b4c089dcbdb74b72eb69c
          sortingKey: "000003"
          type: text-cell-h1
          content: Data Preprocessing for Clustering
          metadata:
            deepnote_app_block_visible: false
            is_collapsed: false
            formattedRanges: []
        - id: 82d4a9d9c8f846f09cc50c500edd7a31
          blockGroup: 7596460816c44a64bf848e311385c79c
          sortingKey: "000004"
          contentHash: 2e048a0e
          type: code
          content: >-
            # Feature groups for clustering


            # 1. Demographics/General Health

            demographic_cols = [
                '_AGEG5YR',   # Age in 5-year groups:
                              # 1=18-24, 2=25-29, 3=30-34, 4=35-39 ..., 13=80+, 14=Don't Know/Missing

                '_RFHLTH',    # General health status:
                              # 1 = Good/Better Health, 2 = Fair/Poor, 9 = Don't Know/Missing

                'VETERAN3'    # Veteran status:
                              # 1 = Yes, 2 = No, 7 = Don't Know, 9 = Refused, BLANK = Not asked/Missing
            ]


            # 2. Cardiovascular/Chronic Disease History

            cardio_chronic_cols = [
                'CVDSTRK3',   # Stroke history:
                              # 1 = Yes, 2 = No, 7 = Don't Know, 9 = Refused, BLANK = Not asked/Missing

                'CHCCOPD3',   # COPD / chronic bronchitis / emphysema:
                              # 1 = Yes, 2 = No, 7 = Don't Know, 9 = Refused, BLANK = Not asked/Missing

                'CHCKDNY2',   # Chronic kidney disease:
                              # 1 = Yes, 2 = No, 7 = Don't Know, 9 = Refused, BLANK = Not asked/Missing

                'DIABETE4',   # Diabetes status:
                              # 1 = Yes, 2 = Yes (pregnancy only), 3 = No, 4 = Pre-diabetes/borderline, 
                              # 7 = Don't Know, 9 = Refused, BLANK = Not asked/Missing

                'HAVARTH4',   # Arthritis:
                              # 1 = Yes, 2 = No, 7 = Don't Know, 9 = Refused, BLANK = Not asked/Missing

                'CHCOCNC1',   # Melanoma or other cancer history:
                              # 1 = Yes, 2 = No, 7 = Don't Know, 9 = Refused, BLANK = Not asked/Missing

                'CHCSCNC1',   # Skin cancer history:
                              # 1 = Yes, 2 = No, 7 = Don't Know, 9 = Refused, BLANK = Not asked/Missing

                'INSULIN1'    # Currently using insulin:
                              # 1 = Yes, 2 = No, 7 = Don't Know, 9 = Refused, BLANK = Not asked/Missing
            ]


            # 3. Physical Function/Disability

            disability_cols = [
                'DIFFWALK',   # Difficulty walking/climbing stairs:
                              # 1 = Yes, 2 = No, 7 = Don't Know, 9 = Refused, BLANK = Not asked/Missing

                'DIFFALON',   # Difficulty doing errands alone:
                              # 1 = Yes, 2 = No, 7 = Don't Know, 9 = Refused, BLANK = Not asked/Missing

                'DIFFDRES',   # Difficulty dressing/bathing:
                              # 1 = Yes, 2 = No, 7 = Don't Know, 9 = Refused, BLANK = Not asked/Missing

                'DEAF',       # Serious hearing difficulty:
                              # 1 = Yes, 2 = No, 7 = Don't Know, 9 = Refused, BLANK = Not asked/Missing

                'BLIND',      # Serious vision difficulty:
                              # 1 = Yes, 2 = No, 7 = Don't Know, 9 = Refused, BLANK = Not asked/Missing

                'CIMEMLO1',   # Cognitive decline (memory/confusion affecting life):
                              # 1 = Yes, 2 = No, 7 = Don't Know, 9 = Refused, BLANK = Not asked/Missing

                'FEETSORE'    # Foot sores (diabetes complication indicator):
                              # 1 = Yes, 2 = No, 7 = Don't Know, 9 = Refused, BLANK = Not asked/Missing
            ]


            # 4. Physical/Mental Health Burden

            health_burden_cols = [
                'PHYSHLTH',   # 1-30 = Days physical health not good, 88 = None, 77 = Don't Know, 99 = Refused,
                              # BLANK = Not asked/Missing

                'POORHLTH'    # 1-30 = Days poor health (physical/mental) limited usual activities, 88 = None, 
                              # 77 = Don't Know, 99 = Refused, BLANK = Not asked/Missing
            ]


            # 5. Healthcare Access/Preventive Care

            healthcare_cols = [
                'PERSDOC3',   # Do you have a Personal doctor (one or group):
                              # 1 = Yes, one, 2 = More than one, 3 = No, 7 = Don't Know, 9 = Refused, BLANK = Not asked/Missing

                'CHECKUP1',   # Last routine checkup:
                              # 1 = <1 year, 2 = 1–2 year, 3 = 2–5 years, 4 = >5 years
                              # 7 = Don't Know, 8 = Never, 9 = Refused, BLANK = Not asked/Missing

                'FLUSHOT7',   # Flu shot past 12 months:
                              # 1 = Yes, 2 = No, 7 = Don't Know, 9 = Refused, BLANK = Not asked/Missing

                'PNEUVAC4'    # Pneumonia vaccine:
                              # 1 = Yes, 2 = No, 7 = Don't Know, 9 = Refused, BLANK = Not asked/Missing
            ]


            # 6. Socioeconomic Status

            socioeconomic_cols = [
                '_INCOMG1'    # Income group:
                              # 1 = <$15k, 2 = $15–<25k, 3 = $25–<35k, 4 = $35–<50k, 5 = $50–<100k, 6 = $100-<$200k
                              # 7 = <$200k, 9 = Don't Know/Missing
            ]


            # 7. Smoking/Tobacco Exposure

            smoking_cols = [
                '_SMOKER3',   # Smoking status:
                              # 1 = Current smoker (every day), 2 = Current smoker (some days), 3 = Former smoker
                              # 4 = Never smoked, 9 = Don't Know/Missing

                'LCSNUMCG',   # 1-300 Number of Cigarettes per day, 777 = Don't Know, 999 = Refused, BLANK = Not asked/missing

                '_LCSYSMK',   # 0-100 Years smoked, BLANK = Not asked/missing

                '_LCSYQTS'    # 0-100 Years since quitting smoking, BLANK = Not asked/missing, HIDDEN 
            ]



            # 8. Physical Activity (Treatment Variable)

            activity_cols = [
                '_TOTINDA'    # Physical activity in past 30 days:
                              # 1 = Yes (active), 2 = No (inactive), 9 = Don't Know/Missing
            ]
          metadata:
            execution_context_id: f96c8630-e291-475d-9374-ee9251eb52f6
        - id: 14c6d62d63e54c8faa4863e403cc8699
          blockGroup: 47a866ae5ee544519c8bdb59d2b38378
          sortingKey: "000005"
          contentHash: c230ca1
          type: code
          content: >-
            # Copy clustering dataset and replace common BRFSS codes to NAN

            df_clean = cluster_df.copy()

            df_clean = df_clean.replace([7, 9, 77, 99], np.nan)


            # Fix "None" coding

            if "PHYSHLTH" in df_clean.columns:
                df_clean["PHYSHLTH"] = df_clean["PHYSHLTH"].replace(88, 0)

            if "POORHLTH" in df_clean.columns:
                df_clean["POORHLTH"] = df_clean["POORHLTH"].replace(88, 0)

            # Missingness check

            print(df_clean.isnull().mean().sort_values(ascending=False))
          metadata:
            execution_context_id: f96c8630-e291-475d-9374-ee9251eb52f6
        - id: 4038eb88ccc343ecb4880c02439165c4
          blockGroup: 7cfd77f72fdd4c7994eaf87bcae92ec6
          sortingKey: "000006"
          contentHash: e5f98fb7
          type: code
          content: >-
            # Keep features with less than 50% missingness

            keep_cols = [
                '_AGEG5YR', '_RFHLTH', 'VETERAN3',
                'CVDSTRK3', 'CHCCOPD3', 'CHCKDNY2', 'DIABETE4',
                'HAVARTH4', 'CHCOCNC1', 'CHCSCNC1',
                'DIFFWALK', 'DIFFALON', 'DIFFDRES',
                'DEAF', 'BLIND',
                'PHYSHLTH', 'POORHLTH',
                'PERSDOC3', 'CHECKUP1', 'FLUSHOT7',
                '_INCOMG1',
                '_SMOKER3',
                '_TOTINDA'
            ]


            drop_cols = [
                "INSULIN1",
                "FEETSORE",
                "CIMEMLO1",
                "_LCSYSMK",
                "_LCSYQTS",
                "LCSNUMCG"
            ]


            df_clean = df_clean[keep_cols].copy()


            # Median imputation

            df_imputed = df_clean.fillna(df_clean.median())


            # Standardization

            scaler = StandardScaler()

            X = scaler.fit_transform(df_imputed)


            print("Final matrix shape:", X.shape)
          metadata:
            execution_context_id: f96c8630-e291-475d-9374-ee9251eb52f6
        - id: c0919cd8643f4811a44b0306c1148730
          blockGroup: 154c44c369954b98ad6afe4a3d6deadc
          sortingKey: "000007"
          type: text-cell-h1
          content: Dimensionality Reduction (PCA)
          metadata:
            formattedRanges: []
        - id: fe167a5b2d454477adc17a3db5ba8984
          blockGroup: 4060f26db46b48459dddd624555dac80
          sortingKey: "000008"
          contentHash: 83c81f0b
          type: code
          content: >+
            # Fit PCA 

            pca = PCA()

            X_pca = pca.fit_transform(X)


            # Explained variance plot

            plt.figure(figsize=(8,5))

            plt.plot(np.cumsum(pca.explained_variance_ratio_), marker='o')

            plt.xlabel("Number of Components")

            plt.ylabel("Cumulative Explained Variance")

            plt.title("PCA Explained Variance")

            plt.grid()

            plt.show()

          metadata:
            execution_context_id: f96c8630-e291-475d-9374-ee9251eb52f6
