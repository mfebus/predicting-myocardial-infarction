          contentHash: 4c221ca8
          type: code
          content: >-
            # Parameters

            path = '/work/model_myocardial_infarction/dataset/processed_data.csv'

            df = pd.read_csv(path)

            TARGET = '_MICHD'

            CHUNK  = 9

            P_THRESHOLD = 0.05

            CV_THRESHOLD = 0.09 #binary

            CORR_THRESHOLD = 0.1 #continuous
          metadata:
            execution_context_id: 7984034e-bdad-4260-a9ea-562fabb97b0f
        - id: 974f643f6db94f0b91e1a02274d352e0
          blockGroup: 258e8e8be696441386105a99066a43bd
          sortingKey: "000007"
          contentHash: 10dcfc82
          type: code
          content: >-
            binary_cols = [c for c in df.columns
                           if c != TARGET and df[c].nunique() == 2]
            continuous_cols = [c for c in df.select_dtypes("number").columns
                               if c != TARGET and df[c].nunique() >= 3]
          metadata:
